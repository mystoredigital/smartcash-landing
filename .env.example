# === GHL Integration (server-side, seguras) ===
GHL_API_KEY=                         # API Key de GHL (Settings > Business Profile > API Keys)
GHL_LOCATION_ID=                     # Location/sub-account ID de GHL

# === Admin Notifications ===
ADMIN_EMAIL=                         # Email del admin que recibe notificaciones de nuevos leads

# === GHL Widget (client-side) ===
NEXT_PUBLIC_GHL_WIDGET_ID=           # ID del chat widget (opcional)

# === Facebook Pixel ===
NEXT_PUBLIC_FB_PIXEL_ID=             # ID del Pixel de Facebook

# === Configuracion del Sitio ===
NEXT_PUBLIC_SITE_URL=                # URL de produccion
NEXT_PUBLIC_CONTACT_EMAIL=           # Email de contacto visible
NEXT_PUBLIC_CONTACT_PHONE=           # Telefono/WhatsApp (+593...)
NEXT_PUBLIC_WHATSAPP_URL=            # Link directo de WhatsApp

# === Analytics (opcional) ===
NEXT_PUBLIC_GA_ID=                   # Google Analytics 4
